rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 정보: 누구나 읽기, 쓰기 불가
    match /users/{nickname} {
      allow read: if true;
      allow write: if false;
    }

    // 토론: 누구나 읽기/쓰기 (관리자 캘린더 수정, Cloud Functions 상태 전환)
    match /debates/{debateId} {
      allow read: if true;
      allow write: if true;

      // 서브컬렉션: 누구나 읽기/쓰기
      match /{subcollection}/{docId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // 서버 시간 동기화용
    match /_meta/{doc} {
      allow read, write: if true;
    }
  }
}
